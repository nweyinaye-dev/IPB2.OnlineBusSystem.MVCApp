@model GetRoutesResponse
@{
    ViewData["Title"] = "Route Management";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-0">
                <i class="fa-solid fa-route"></i>
                @* <i class="fas fa-bus-alt me-2"></i> *@

                Route Management</h2>
            <p class="text-muted small mb-0">Manage your route details.</p>
        </div>
        <button type="button" class="btn btn-success px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#createRouteModal">
            <i class="fas fa-plus-circle me-1"></i> Add New Route
        </button>
    </div>

    <!-- Bus Table -->
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4 py-3">Route Name</th>
                        <th class="py-3">Origin</th>
                        <th class="py-3">Destination</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Routes != null && Model.Routes.Any())
                    {
                        foreach (var route in Model.Routes)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold">@route.RouteName</span>
                                </td>
                                <td>@route.Origin</td>
                                <td>@route.Destination</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-outline-primary" title="Edit"
                                                data-bs-toggle="modal" data-bs-target="#editRouteModal"
                                                data-id="@route.Id" data-name="@route.RouteName" data-origin="@route.Origin"
                                                data-destination="@route.Destination">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger ms-1" title="Delete"
                                                data-bs-toggle="modal" data-bs-target="#deleteRouteModal"
                                                data-id="@route.Id" data-name="@route.RouteName">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted mb-3">
                                    <i class="fas fa-folder-open fa-3x opacity-25"></i>
                                </div>
                                <h5 class="text-muted">No Route Records Found</h5>
                            </td>
                        </tr>
                    }
                </tbody>
             </table>
        </div>
    </div>
        
    <!-- Pagination -->
    @* @if (Model != null && Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="?pageNumber=@(Model.PageNumber - 1)&searchTerm=@Context.Request.Query["searchTerm"]">
                        <i class="fas fa-chevron-left me-1"></i> Previous
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link shadow-sm" href="?pageNumber=@i&searchTerm=@Context.Request.Query["searchTerm"]">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="?pageNumber=@(Model.PageNumber + 1)&searchTerm=@Context.Request.Query["searchTerm"]">
                        Next <i class="fas fa-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    } *@

</div>
<!-- Modal Partials -->
<partial name="Create" />
<partial name="Edit" model="new UpsertRouteRequest()" />
<style>
    .card {
        transition: transform 0.2s;
    }

    .table thead th {
        font-weight: 500;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .btn-group .btn {
        padding: 0.35rem 0.6rem;
    }

    .page-link {
        border-radius: 8px !important;
        margin: 0 3px;
        color: #333;
        border: 1px solid #dee2e6;
    }

    .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
</style>
@section Scripts {
    <script>
        // Edit Modal Data Sync
        const editRouteModal = document.getElementById('editRouteModal');
        if (editRouteModal) {
            editRouteModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                const origin = button.getAttribute('data-origin');
                const destination = button.getAttribute('data-destination');

                editBusModal.querySelector('#editRouteId').value = id;
                editBusModal.querySelector('#editRouteName').value = name;
                editBusModal.querySelector('#editOrigin').value = origin;
                editBusModal.querySelector('#editDestination').value = destination;
            });
        }

        // Delete Modal Data Sync
        const deleteBusModal = document.getElementById('deleteBusModal');
        if (deleteBusModal) {
            deleteBusModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const no = button.getAttribute('data-no');

                deleteBusModal.querySelector('#deleteBusId').value = id;
                deleteBusModal.querySelector('#deleteBusNoDisplay').textContent = no;
            });
        }
    </script>
}
